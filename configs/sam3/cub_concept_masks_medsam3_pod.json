{
  "dataset": "cub",
  "split": "train",
  "concept_set": "concept_files/cub_filtered.txt",
  "output_root": "saved_activations/sam3_concept_masks",
  "cache_name": "cub_medsam3_concept_masks_v1",
  "dry_run": true,
  "subset": {
    "max_images": 2,
    "max_concepts": 3,
    "image_indices": null,
    "concept_indices": null
  },
  "sam3": {
    "backend": "medsam3_lora",
    "repo_path": "/workspace/MedSAM3",
    "model_config": "/workspace/MedSAM3/configs/full_lora_config.yaml",
    "lora_weights": "/workspace/MedSAM3_v1/best_lora_weights.pt",
    "device": "cuda",
    "resolution": 1008,
    "prompt_template": "{concept}",
    "score_threshold": 0.1,
    "nms_iou_threshold": 0.5,
    "max_masks_per_concept": 1,
    "mask_selection": "top_score",
    "continue_on_error": true
  },
  "cache": {
    "schema_version": "sam3_concept_masks_v1",
    "mask_format": "npz_bool_hxw_v1",
    "mask_coordinates": "original_image_pixels",
    "write_metadata_json": true,
    "write_preview_png": true,
    "preview_alpha": 0.45
  },
  "notes": [
    "Pod-oriented config for /workspace/SAVLGCBM with /workspace/MedSAM3 installed.",
    "Use --run to disable dry_run. Base facebook/sam3 access still requires Hugging Face authentication or a local base checkpoint.",
    "MedSAM3 inference currently uses the default 1008 resolution; 512 triggers a SAM3 RoPE shape assertion."
  ]
}
