{
  "dataset": "cub",
  "split": "train",
  "concept_set": "concept_files/cub_filtered.txt",
  "output_root": "saved_activations/sam3_concept_masks",
  "cache_name": "cub_groundingdino_sam3_20img_audit_v1",
  "dry_run": true,
  "subset": {
    "max_images": 20,
    "max_concepts": 20,
    "image_indices": null,
    "concept_indices": null
  },
  "concept_processing": {
    "filter_before_masking": true,
    "allowed_localizability": [
      "part_localizable",
      "region_localizable"
    ],
    "overrides": {
      "a white stripe above the eye": {
        "normalized_prompt": "bird eyebrow stripe",
        "localizability": "part_localizable"
      },
      "a white patch on the wing": {
        "normalized_prompt": "bird wing patch",
        "localizability": "part_localizable"
      },
      "shiny black eyes": {
        "normalized_prompt": "bird eye",
        "localizability": "part_localizable"
      }
    }
  },
  "sam3": {
    "backend": "groundingdino_sam3",
    "mask_selection": "score_area_constrained",
    "selection_score_power": 1.0,
    "selection_area_power": 0.2,
    "min_mask_area_ratio": 0.002,
    "max_mask_area_ratio": 0.35,
    "selection_fallback": "top_score",
    "candidate_top_k": 5,
    "max_masks_per_concept": 1,
    "continue_on_error": true,
    "groundingdino": {
      "repo_path": "GroundingDINO",
      "config": "GroundingDINO/groundingdino/config/GroundingDINO_SwinB_cfg.py",
      "checkpoint": "GroundingDINO/groundingdino_swinb_cogcoor.pth",
      "device": "cuda",
      "resize": 800,
      "box_threshold": 0.25,
      "nms_iou_threshold": 0.5,
      "top_k": 5
    },
    "sam3_box": {
      "repo_path": "/workspace/sam3",
      "load_from_hf": true,
      "bpe_path": "/workspace/sam3/sam3/assets/bpe_simple_vocab_16e6.txt.gz",
      "device": "cuda",
      "inference_dtype": "float32",
      "multimask_output": true,
      "mask_threshold": 0.0
    }
  },
  "cache": {
    "schema_version": "sam3_concept_masks_v1",
    "mask_format": "npz_bool_hxw_v1",
    "mask_coordinates": "original_image_pixels",
    "write_metadata_json": true,
    "write_preview_png": true,
    "write_candidate_previews": true,
    "preview_alpha": 0.45
  },
  "notes": [
    "GroundingDINO proposal boxes followed by SAM3 box-prompted masks.",
    "Concepts are filtered and normalized before mask generation."
  ]
}
